# 阿里云服务配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./smart_learner.db

# ChromaDB本地向量存储
CHROMA_PERSIST_DIR=./chroma_data

# 合工大CAS认证
CAS_LOGIN_URL=https://cas.hfut.edu.cn/cas/login
CAS_VALIDATE_URL=https://cas.hfut.edu.cn/cas/serviceValidate

# 应用配置
APP_SECRET_KEY=your-secret-key-change-in-production
APP_HOST=0.0.0.0
APP_PORT=8000

# 嵌入模型配置
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_DIMENSION=1536

# LLM模型配置
LLM_MODEL=qwen-plus
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
